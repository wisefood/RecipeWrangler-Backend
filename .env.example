# RecipeWrangler Backend — environment variable template
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── Neo4j ──────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=secret
# NEO4J_CONNECT_TIMEOUT=5.0

# ── Groq LLM (required for /search and /profile) ──────────────────────────────
GROQ_API_KEY=gsk-...
# Model used for recipe search and recipe parsing.
# Must be a valid Groq model ID — see https://console.groq.com/docs/models
SEARCH_MAIN_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# GUARDRAILS_MODEL=llama-3.1-8b-instant
# SEARCH_TEMPERATURE=0.0

# ── Elasticsearch ──────────────────────────────────────────────────────────────
ELASTIC_URL=http://localhost:9200
ELASTIC_INDEX=recipes
# ELASTIC_TIMEOUT=3.0

# ── Chroma ─────────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8000

# ── PostgreSQL (nutrition data) ────────────────────────────────────────────────
NUTRITION_HOST=localhost
NUTRITION_PORT=5432
NUTRITION_DB=nutrition
NUTRITION_USER=postgres
NUTRITION_PASSWORD=secret

# ── API server ─────────────────────────────────────────────────────────────────
# PORT=8001

# ── CORS (comma-separated origins; * allows all — dev only) ───────────────────
# CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Profiling pipeline versioning (optional) ──────────────────────────────────
# NUTRITION_PROFILE_PIPELINE_VERSION=v1
# NUTRITION_PROFILE_MAPPING_VERSION=v1
# NUTRITION_PROFILE_EMBEDDING_MODEL=default
# NUTRITION_PROFILE_RULESET_VERSION=v1
